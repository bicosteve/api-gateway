APP_PORT=5001

# Local Docker Compose maps MySQL/Redis to non-default host ports to avoid
# collisions with services already running on your machine.
MYSQL_HOST_PORT=3307
REDIS_HOST_PORT=6380

DB_URL=jdbc:mysql://mysql:3306/sportsbook?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root
DB_NAME=sportsbook
DB_DRIVER=com.mysql.cj.jdbc.Driver
SQL_MODE=always

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=local-development-jwt-secret-change-me-local-development-jwt-secret
ACCESS_TOKEN_EXPIRATION=3600000
REFRESH_TOKEN_EXPIRATION=604800000

LOGGING_LEVEL=DEBUG
APP_LOGGING=DEBUG

MAILGUN_BASE_URL=https://api.mailgun.net
MAILGUN_API_KEY=
MAILGUN_SANDBOX=
MAILGUN_FROM=

CHAPA_BASE_URL=https://api.chapa.co
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=
CHAPA_CURRENCY=ETB
CHAPA_CALLBACK_URL=http://localhost:5001/api/wallet/webhook/chapa
CHAPA_RETURN_URL=http://localhost:3000/deposit/success
